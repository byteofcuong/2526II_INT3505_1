{
  "info": {
    "_postman_id": "b1b2f4f2-5c91-450f-a7e1-38290f6705f1",
    "name": "Equipment API Tests",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "1. Create Equipment",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 201\", function () {",
              "    pm.response.to.have.status(201);",
              "});",
              "pm.test(\"Response has ID\", function () {",
              "    var jsonData = pm.response.json();",
              "    pm.expect(jsonData).to.have.property('id');",
              "    pm.environment.set(\"eq_id\", jsonData.id);",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n    \"code\": \"EQ-1001\",\n    \"name\": \"Lenovo Thinkpad\",\n    \"type\": \"Laptop\",\n    \"install_date\": \"2024-04-20\"\n}"
        },
        "url": {
          "raw": "{{base_url}}/equipments",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "equipments"
          ]
        }
      }
    },
